# Copy sang .env và chỉnh cho production
PORT=3001
# API kết nối bằng role app_login (non-superuser → RLS có hiệu lực)
DATABASE_URL=postgres://app_login:app_pw@localhost:55432/vietcms
# Seed dùng role postgres (bypass RLS)
ADMIN_DATABASE_URL=postgres://postgres:pw@localhost:55432/vietcms
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=15m
CORS_ORIGIN=http://localhost:3000
