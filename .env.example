# docker-compose env — copy sang .env và ĐẶT giá trị thật.
# .env đã bị .gitignore (không commit secrets).

# Bắt buộc — secret ký JWT (production: dùng chuỗi ngẫu nhiên dài, hoặc secret manager)
JWT_SECRET=change-me-please-32chars-min

# Tuỳ chọn (có default)
POSTGRES_PASSWORD=pw
JWT_EXPIRES_IN=15m
CORS_ORIGIN=http://localhost:3000
API_TAG=0.1.0
