{
  "$meta": {
    "name": "VietCMS Design Tokens",
    "version": "1.0.0",
    "theme": "Modern Trust — Blue",
    "date": "2026-07-20",
    "description": "Design tokens nền tảng cho VietCMS — CMS SaaS no-code cho đội marketing mid-market Việt. Verified WCAG 2.1 AA.",
    "usage": "Consume trong Tailwind config, CSS variables, hoặc styled-system. Mọi giá trị màu/spacing/type phải lấy từ đây, không hardcode."
  },

  "color": {
    "primary": {
      "$comment": "Blue — brand, trust. 600 là base cho nút/link (white text đạt 5.17:1). 700 hover, 800 pressed.",
      "50":  "#EFF5FF",
      "100": "#DBE8FE",
      "200": "#BFD6FE",
      "300": "#93BBFD",
      "400": "#609AFA",
      "500": "#3B82F6",
      "600": "#2563EB",
      "700": "#1D4ED8",
      "800": "#1E40AF",
      "900": "#1E3A8A",
      "950": "#172554"
    },
    "neutral": {
      "$comment": "Cool gray — chiếm ~80% UI. 900 body text, 600 secondary, 500 muted, 200 border, 50 surface.",
      "0":   "#FFFFFF",
      "50":  "#F8FAFC",
      "100": "#F1F5F9",
      "200": "#E2E8F0",
      "300": "#CBD5E1",
      "400": "#94A3B8",
      "500": "#64748B",
      "600": "#475569",
      "700": "#334155",
      "800": "#1E293B",
      "900": "#0F172A",
      "950": "#020617"
    },
    "accent": {
      "$comment": "Violet — dành riêng cho AI features (trợ lý soạn nội dung). Tách biệt để user nhận diện 'đây là AI'.",
      "50":  "#F5F3FF",
      "100": "#EDE9FE",
      "300": "#C4B5FD",
      "500": "#8B5CF6",
      "600": "#7C3AED",
      "700": "#6D28D9"
    },
    "semantic": {
      "success":    { "base": "#059669", "fg": "#065F46", "bg": "#D1FAE5", "border": "#6EE7B7" },
      "warning":    { "base": "#D97706", "fg": "#92400E", "bg": "#FEF3C7", "border": "#FCD34D" },
      "error":      { "base": "#DC2626", "fg": "#991B1B", "bg": "#FEE2E2", "border": "#FCA5A5" },
      "info":       { "base": "#2563EB", "fg": "#1E40AF", "bg": "#DBEAFE", "border": "#93C5FD" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Roboto, sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace",
      "$comment": "Inter — hỗ trợ đầy đủ dấu tiếng Việt, variable font, tối ưu màn hình. Fallback system-ui."
    },
    "fontSize": {
      "display": { "size": "48px", "lineHeight": "1.15", "weight": 700, "tracking": "-0.02em", "use": "Hero / landing" },
      "h1":      { "size": "32px", "lineHeight": "1.25", "weight": 700, "tracking": "-0.02em", "use": "Tiêu đề trang" },
      "h2":      { "size": "24px", "lineHeight": "1.3",  "weight": 600, "tracking": "-0.01em", "use": "Tiêu đề section" },
      "h3":      { "size": "20px", "lineHeight": "1.4",  "weight": 600, "tracking": "0",       "use": "Tiêu đề phụ" },
      "h4":      { "size": "16px", "lineHeight": "1.4",  "weight": 600, "tracking": "0",       "use": "Tiêu đề card" },
      "body-lg": { "size": "18px", "lineHeight": "1.6",  "weight": 400, "tracking": "0",       "use": "Đoạn dài" },
      "body":    { "size": "16px", "lineHeight": "1.5",  "weight": 400, "tracking": "0",       "use": "UI mặc định" },
      "body-sm": { "size": "14px", "lineHeight": "1.5",  "weight": 400, "tracking": "0",       "use": "Phụ, label" },
      "caption": { "size": "12px", "lineHeight": "1.4",  "weight": 400, "tracking": "0",       "use": "Meta, hint" },
      "overline":{ "size": "12px", "lineHeight": "1.2",  "weight": 600, "tracking": "0.06em",  "use": "Nhãn (UPPERCASE)" }
    },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },

  "spacing": {
    "$comment": "8px grid. Chỉ dùng giá trị trong scale, không tự bịa '13px'. base = 16px.",
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px",
    "16": "64px", "20": "80px", "24": "96px"
  },

  "radius": {
    "sm": "6px", "md": "8px", "lg": "12px", "xl": "16px", "2xl": "24px", "full": "9999px"
  },

  "shadow": {
    "xs": "0 1px 2px rgba(15,23,42,0.06)",
    "sm": "0 1px 3px rgba(15,23,42,0.08), 0 1px 2px rgba(15,23,42,0.04)",
    "md": "0 4px 8px -2px rgba(15,23,42,0.10), 0 2px 4px -2px rgba(15,23,42,0.06)",
    "lg": "0 12px 20px -4px rgba(15,23,42,0.10), 0 4px 8px -4px rgba(15,23,42,0.06)",
    "xl": "0 24px 32px -8px rgba(15,23,42,0.14), 0 8px 12px -6px rgba(15,23,42,0.08)",
    "focus": "0 0 0 3px rgba(37,99,235,0.35)"
  },

  "motion": {
    "duration": {
      "instant": "0ms", "fast": "150ms", "normal": "250ms", "slow": "400ms", "slower": "600ms"
    },
    "easing": {
      "out":     "cubic-bezier(0, 0, 0.2, 1)",
      "in":      "cubic-bezier(0.4, 0, 1, 1)",
      "in-out":  "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring":  "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "$comment": "Honor prefers-reduced-motion — set duration ~0.01ms khi reduce."
  },

  "breakpoint": {
    "$comment": "Mobile-first. Design mobile trước, scale up.",
    "mobile": "0px",
    "tablet": "640px",
    "desktop": "1024px",
    "wide": "1280px",
    "maxContentWidth": "1280px"
  },

  "zIndex": {
    "base": 0, "dropdown": 1000, "sticky": 1100, "overlay": 1200,
    "modal": 1300, "toast": 1400, "tooltip": 1500
  },

  "component": {
    "button": {
      "height": { "sm": "32px", "md": "40px", "lg": "48px" },
      "paddingX": { "sm": "12px", "md": "16px", "lg": "20px" },
      "radius": "8px",
      "minTouchTarget": "44px"
    },
    "input": {
      "height": "40px",
      "paddingX": "12px",
      "radius": "8px",
      "borderColor": "{color.neutral.300}",
      "focusRing": "{shadow.focus}"
    },
    "focusRing": {
      "width": "3px",
      "color": "rgba(37,99,235,0.35)",
      "offset": "0px",
      "$comment": "Visible ở mọi element interactive. Contrast viền ≥ 3:1."
    }
  },

  "a11y": {
    "contrast": {
      "bodyTextMin": "4.5:1",
      "largeTextMin": "3:1",
      "uiComponentMin": "3:1"
    },
    "verified": {
      "neutral-900_on_white": "16.1:1 (AAA)",
      "neutral-600_on_white": "7.4:1 (AAA)",
      "neutral-500_on_white": "4.8:1 (AA)",
      "white_on_primary-600": "5.17:1 (AA)",
      "primary-700_on_white": "6.3:1 (AA)",
      "white_on_error-base(#DC2626)": "4.5:1 (AA)"
    }
  }
}
